{
  "name": "@xiankq/openapi-typescript-expand",
  "type": "module",
  "version": "1.2.1",
  "author": {
    "name": "xiankq"
  },
  "license": "MIT",
  "homepage": "https://github.com/xiankq/openapi-typescript-expand#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiankq/openapi-typescript-expand.git"
  },
  "bugs": {
    "url": "https://github.com/xiankq/openapi-typescript-expand/issues"
  },
  "keywords": [
    "openapi",
    "swagger",
    "codegen",
    "typescript"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "test": "tsx demo/index",
    "bumpp": "bumpp -r",
    "lint": "eslint . --fix",
    "taze": "taze -w -r major minor patch",
    "============[CI]==========": "",
    "build:ci": "unbuild",
    "publish:ci": "pnpm publish -r --no-git-checks --access public"
  },
  "dependencies": {
    "openapi-typescript": "^7.13.0",
    "pinyin-pro": "^3.28.1",
    "swagger2openapi": "^7.0.8"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^25.9.2",
    "@types/swagger2openapi": "^7.0.4",
    "axios": "^1.17.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "taze": "^19.14.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1"
  }
}
